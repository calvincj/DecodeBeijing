# ── Local dev (Docker Compose) ────────────────────────────────────────────────
# Run `docker compose up -d` to start postgres + elasticsearch locally.
# Docker does NOT auto-start after a Mac reboot — enable that in Docker Desktop settings.
DB_PASSWORD=localdev
DATABASE_URL=postgresql+asyncpg://decode:localdev@localhost:5432/decode_beijing
ELASTICSEARCH_URL=http://localhost:9200

# ── Production (Render + Neon) ────────────────────────────────────────────────
# Backend is deployed on Render (render.com) as a Docker web service.
# Database is Neon free tier (neon.tech) — 0.5 GB storage limit, no expiry.
# Note: use `?ssl=require` not `?sslmode=require` — asyncpg requires this form.
# Production DATABASE_URL format:
#   postgresql+asyncpg://<user>:<password>@<host>/neondb?ssl=require
# Set this in Render → your service → Environment, NOT in this file.

# Optional: DeepL API for translating context snippets
# Get one free at deepl.com/pro-api — 500k chars/month free tier
DEEPL_API_KEY=

# Required for Claude-based term extraction (analyze_document.py)
# Get one at console.anthropic.com
ANTHROPIC_API_KEY=

# Optional: for scraping rate limiting / proxying
SCRAPER_DELAY_SECONDS=2
SCRAPER_USER_AGENT=Mozilla/5.0 (compatible; academic-research-bot/1.0)
